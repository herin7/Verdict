{
  "expo": {
    "name": "Verdict",
    "slug": "anakin-consensus",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "verdict",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.verdict.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Point your camera at a product to research it.",
        "NSLocationWhenInUseUsageDescription": "Verdict uses your approximate location to show accurate prices and availability on location-gated quick-commerce apps."
      }
    },
    "android": {
      "package": "com.verdict.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/monochrome-icon.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "CAMERA",
        "SYSTEM_ALERT_WINDOW",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_SPECIAL_USE",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Point your camera at a product to research it."
        }
      ],
      "expo-sharing",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-share-intent",
        {
          "androidIntentFilters": [
            "text/*",
            "image/*"
          ],
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          }
        }
      ],
      "./modules/verdict-overlay/app.plugin.js",
      "./modules/verdict-accessibility/app.plugin.js",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Verdict uses your approximate location to show accurate prices and availability on location-gated quick-commerce apps.",
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ]
    ]
  }
}
