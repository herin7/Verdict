ANAKIN_API_KEY=your_anakin_api_key
PORT=8787
# Optional: only needed if AI_POLICY explicitly lists "anthropic" (default chain never does).
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
# Optional: fallback search/scrape provider used when Anakin fails (e.g. out of credits).
# Also powers price/stock monitors for Shopping Missions when set.
FIRECRAWL_API_KEY=
# Public HTTPS base URL of this server - used to register Firecrawl monitor webhooks.
PUBLIC_BASE_URL=
# Shared secret sent as x-verdict-webhook-secret on Firecrawl webhooks.
FIRECRAWL_WEBHOOK_SECRET=

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Shopping Missions need DATABASE_URL. Set to false/0 to force-disable even with DB.
MISSIONS_ENABLED=true

# Supabase Auth (identity only - JWT verification via JWKS, with HS256 fallback)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
# Only needed if your project has NOT been migrated to asymmetric JWT signing keys
# (most projects haven't - this is the default). Find it at:
# Supabase Dashboard > Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=

# Cache TTLs (optional overrides)
REPORT_TTL_DAYS=7
INSIGHT_TTL_DAYS=7
BUY_LINK_TTL_HOURS=24

# AWS Bedrock Mantle (default LLM path for all workloads - GLM only, no Anthropic)
# ap-south-1 (Mumbai) is in-region for zai.glm-5; enable model access in Bedrock console.
BEDROCK_REGION=ap-south-1
# Long-term API key from Bedrock console (Mantle bearer auth - no IAM/SigV4 needed).
BEDROCK_MANTLE_API_KEY=
# Optional override: workload -> model id JSON. Default is zai.glm-5 for every workload.
# identify_image needs a vision-capable id (GLM has none), e.g. {"identify_image":"amazon.nova-lite-v1:0"}
# BEDROCK_MODEL_MAP=
# Optional override: workload -> provider chain JSON. Default is ["bedrock-mantle"] only.
# Do not add "anthropic" unless you intentionally want Anthropic fallback.
# AI_POLICY=

# PostHog server-side analytics (optional - unset means fully disabled, zero behavior change)
POSTHOG_API_KEY=
# PostHog ingestion host - default is US cloud, use https://eu.i.posthog.com for EU
POSTHOG_HOST=https://us.i.posthog.com

# Provider HTTP reliability (optional)
# Wall-clock AbortSignal timeout for Anakin/Firecrawl fetch (default 20000)
PROVIDER_HTTP_TIMEOUT_MS=20000
# Extra attempts after first for 429/5xx/network/timeout (default 2)
PROVIDER_HTTP_RETRIES=2
# Anthropic SDK request timeout ms (default 90000) - unused unless AI_POLICY lists anthropic
# ANTHROPIC_TIMEOUT_MS=90000
