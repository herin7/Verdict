ANAKIN_API_KEY=your_anakin_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-5
PORT=8787
# Optional: fallback search/scrape provider used when Anakin fails (e.g. out of credits).
FIRECRAWL_API_KEY=

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Supabase Auth (identity only - JWT verification via JWKS, with HS256 fallback)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
# Only needed if your project has NOT migrated to asymmetric JWT signing keys
# (most projects haven't - this is the default). Find it at:
# Supabase Dashboard > Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=

# Cache TTLs (optional overrides)
REPORT_TTL_DAYS=7
INSIGHT_TTL_DAYS=7
BUY_LINK_TTL_HOURS=24
