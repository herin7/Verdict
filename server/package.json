{
  "name": "anakin-consensus-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend for the Anakin Consensus Scanner: identifies products from photos and researches internet consensus via Anakin.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:deals": "tsx src/deals/calculator.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^11.1.0",
    "@neondatabase/serverless": "^1.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "jose": "^6.2.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
